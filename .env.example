# Which local Ollama model to use. Default is qwen3:8b (fits comfortably in 36GB RAM).
# Upgrade to qwen3:14b for higher quality at the cost of speed.
OLLAMA_MODEL=qwen3:8b

# Optional per-role model overrides. Each falls back to OLLAMA_MODEL when unset,
# so leaving these commented out preserves the single-model default. Roles let
# you run cheap, mechanical steps on a small model and reserve a stronger model
# for generative/critical work. Available roles:
#   ROUTING   – intent classification (Phase 2)
#   PLANNING  – task planning / supervisor decisions (Phases 3 & 4)
#   ANALYSIS  – job, match, and gap analysis
#   WRITING   – CV bullet drafting and interview prep
#   CRITIQUE  – critic, evidence verifier, evaluator, final approval
#   SYNTHESIS – the final strategy brief
# Example: small model for routing/planning, larger model for writing/critique.
# OLLAMA_MODEL_ROUTING=qwen3:8b
# OLLAMA_MODEL_PLANNING=qwen3:8b
# OLLAMA_MODEL_WRITING=qwen3:14b
# OLLAMA_MODEL_CRITIQUE=qwen3:14b

# Where the Ollama server is listening. Leave as-is for a standard local install.
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Sampling temperature. Lower = more deterministic / grounded (recommended).
OLLAMA_TEMPERATURE=0.2

# Optional fixed sampling seed. Combined with OLLAMA_TEMPERATURE=0 this makes
# runs reproducible (the evals harness sets both by default). Leave unset for
# normal CLI use.
# OLLAMA_SEED=42
