{
  "name": "career-agent-orchestrator",
  "version": "0.1.0",
  "description": "A local CLI that turns a CV + job description into a grounded application pack, built to explore TypeScript agentic patterns (LangGraph.js, LangChain.js, Ollama).",
  "type": "module",
  "scripts": {
    "dev": "tsx src/index.ts",
    "start": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "eval": "tsx src/evals/run-evals.ts"
  },
  "keywords": [
    "langgraph",
    "langchain",
    "ollama",
    "agents",
    "typescript"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@langchain/core": "^1.2.1",
    "@langchain/langgraph": "^1.4.5",
    "@langchain/ollama": "^1.3.0",
    "dotenv": "^17.4.2",
    "langchain": "^1.5.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
